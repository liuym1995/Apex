{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Apex",
  "version": "0.1.0",
  "identifier": "com.companybrain.desktop",
  "build": {
    "beforeDevCommand": "node ../../scripts/desktop-dev-supervisor.mjs",
    "beforeBuildCommand": "node ../../scripts/prepare-tauri-build.mjs",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Apex",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "useLocalToolsDir": true,
    "resources": [
      "resources/local-control-plane/**/*",
      "resources/node/**/*"
    ],
    "windows": {
      "signCommand": "node ../../scripts/windows-sign.mjs %1"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
