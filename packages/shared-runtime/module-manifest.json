  "dependency_rules": [
    "core has no runtime module dependencies (only shared-state and shared-types)",
    "capabilities depends on core only",
    "security has no runtime module dependencies",
    "task-kernel depends on core, capabilities, verification, execution-vocabulary, memory, learning, event-sourcing",
    "verification depends on core only",
    "memory depends on core and security only",
    "learning depends on core, capabilities, and security only",
    "execution-vocabulary depends on core only",
    "policy depends on core only",
    "No module may directly mutate another module's store entries",
    "Cross-module communication must go through typed function calls, not direct state access"
  ]
